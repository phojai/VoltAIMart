# Copy to .env for local overrides (optional — every value below has a working
# dev-only default baked into the code, so `npm install && npm start` works
# with zero configuration). Set real values before deploying to production.

# Signs auth JWTs (server/middleware/auth.js). Any long random string.
JWT_SECRET=

# Encrypts stored LLM/web-search provider API keys at rest (server/lib/secretCrypto.js).
ENCRYPTION_KEY=

# Local dev only — port the Express server listens on (default 4000).
PORT=

# Only needed on Vercel (or anywhere with a read-only filesystem) to persist
# writes — Vercel injects these automatically once you connect an Upstash
# Redis database via the Storage tab. Leave unset for local dev, which always
# uses apps/api/data/db.json instead. See server/store.js.
KV_REST_API_URL=
KV_REST_API_TOKEN=
